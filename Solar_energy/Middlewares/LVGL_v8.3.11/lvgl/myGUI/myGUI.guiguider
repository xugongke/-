									"dst": "custom_code",
									"bindCondi": "",
									"actionList": {
										"custom_code": {
											"inc_c": "",
											"code_c": "        lv_group_remove_all_objs(g_keypad_group);//清空group中的所有组件\r\n        //给group添加新组件\r\n        lv_group_add_obj(g_keypad_group, guider_ui.screen_user_detail);\r\n        //将按键添加进焦点组\r\n        lv_indev_set_group(indev_keypad, g_keypad_group);\r\n        //设置初始焦点\r\n        lv_group_focus_obj(guider_ui.screen_user_detail);",
											"inc_py": "",
											"code_py": ""
										}
									}
